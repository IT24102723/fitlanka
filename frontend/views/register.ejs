<%- include('partials/header') %>

<div class="container py-4">
  <div class="text-center mb-4">
    <h2 class="fw-bold display-6">Join <span class="text-warning">FitLanka</span></h2>
    <p class="text-muted">Create your account and start your fitness journey</p>
  </div>
  <div class="row justify-content-center">
    <div class="col-lg-10">
      <div class="row align-items-stretch g-0 shadow-lg rounded-4 overflow-hidden">
        <div class="col-md-5 d-none d-md-flex flex-column" style="background:url('https://images.unsplash.com/photo-1518611012118-696072aa579a?w=800&h=800&fit=crop') center center / cover no-repeat;">
          <div class="p-5 d-flex flex-column justify-content-center h-100" style="background:linear-gradient(135deg,rgba(15,12,41,0.85),rgba(48,43,99,0.7));">
            <h2 class="text-white fw-bold display-6">Start Your Journey</h2>
            <p class="text-white-50 mb-4">Join hundreds of Sri Lankans transforming their lives with certified fitness coaches.</p>
            <div class="text-white mb-2"><i class="bi bi-person-check-fill text-warning me-2"></i> Register as Coach or Member</div>
            <div class="text-white mb-2"><i class="bi bi-shield-check text-warning me-2"></i> Verified by Admin</div>
            <div class="text-white"><i class="bi bi-credit-card text-warning me-2"></i> Pay in LKR via PayHere</div>
          </div>
        </div>
        <div class="col-md-7 bg-white p-4">
          <div class="d-flex justify-content-center mb-3">
            <div class="btn-group rounded-pill overflow-hidden shadow-sm" role="group">
              <input type="radio" class="btn-check" name="roleRadio" id="roleCoach" value="coach" checked>
              <label class="btn btn-outline-warning px-4 py-2 fw-bold" for="roleCoach"><i class="bi bi-person-badge"></i> Coach</label>
              <input type="radio" class="btn-check" name="roleRadio" id="roleMember" value="member">
              <label class="btn btn-outline-warning px-4 py-2 fw-bold" for="roleMember"><i class="bi bi-person"></i> Member</label>
            </div>
          </div>

          <form action="/register" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="role" id="roleInput" value="coach">

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-medium small">Full Name</label>
                <input type="text" name="name" class="form-control" placeholder="Your full name" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-medium small">Email</label>
                <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
              </div>
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-medium small">Password</label>
                <div class="input-group">
                  <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                  <input type="password" name="password" class="form-control" placeholder="Create a password" required>
                </div>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-medium small">Phone</label>
                <div class="input-group">
                  <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                  <input type="text" name="phone" class="form-control" placeholder="07X XXX XXXX" required>
                </div>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-medium small">District</label>
                <select name="district" class="form-select" id="regDistrict" onchange="updateCityDropdown('regDistrict','regCity','')">
                  <option value="">Select your district</option>
                </select>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-medium small">City</label>
                <select name="city" class="form-select" id="regCity" disabled>
                  <option value="">First select a district</option>
                </select>
              </div>
            </div>

            <div id="coachFields">
              <hr class="my-2">
              <div class="d-flex align-items-center mb-2">
                <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-2"><i class="bi bi-award-fill text-warning"></i></div>
                <h6 class="fw-bold mb-0">Coach Details</h6>
              </div>
              <div class="row">
                <div class="col-md-4 mb-2">
                  <label class="form-label fw-medium small">Experience (years)</label>
                  <input type="number" name="experience" class="form-control form-control-sm" placeholder="e.g. 5">
                </div>
                <div class="col-md-4 mb-2">
                  <label class="form-label fw-medium small">Monthly Rate (LKR)</label>
                  <input type="number" name="ratePerMonth" class="form-control form-control-sm" placeholder="e.g. 5000">
                </div>
                <div class="col-md-4 mb-2">
                  <label class="form-label fw-medium small">Specialties</label>
                  <input type="text" name="specialties" class="form-control form-control-sm" placeholder="e.g. Yoga, Cardio">
                </div>
              </div>
              <div class="mb-2">
                <label class="form-label fw-medium small">Bio</label>
                <textarea name="bio" class="form-control form-control-sm" rows="2" placeholder="Tell members about your coaching style..."></textarea>
              </div>
              <div class="mb-2">
                  <label class="form-label fw-medium small">Profile Photo</label>
                  <input type="file" name="profileImage" class="form-control form-control-sm" accept=".jpg,.jpeg,.png">
                </div>
                <div class="mb-2">
                  <label class="form-label fw-medium small">Certificates</label>
                  <input type="file" name="certificates" class="form-control form-control-sm" multiple accept=".jpg,.jpeg,.png,.pdf">
                </div>
              </div>

            <div id="memberFields" style="display:none;">
              <hr class="my-2">
              <div class="d-flex align-items-center mb-2">
                <div class="bg-success bg-opacity-10 p-2 rounded-3 me-2"><i class="bi bi-person-fill text-success"></i></div>
                <h6 class="fw-bold mb-0">Member Details</h6>
              </div>
              <div class="row">
                <div class="col-md-4 mb-2">
                  <label class="form-label fw-medium small">Age</label>
                  <input type="number" name="age" class="form-control form-control-sm" placeholder="Your age">
                </div>
                <div class="col-md-4 mb-2">
                  <label class="form-label fw-medium small">Gender</label>
                  <select name="gender" class="form-select form-select-sm">
                    <option value="">Select</option>
                    <option value="male">Male</option>
                    <option value="female">Female</option>
                  </select>
                </div>
                <div class="col-md-4 mb-2">
                  <label class="form-label fw-medium small">Goals</label>
                  <input type="text" name="fitnessGoals" class="form-control form-control-sm" placeholder="e.g. Lose weight">
                </div>
              </div>
              <div class="mb-2">
                  <label class="form-label fw-medium small">Health Conditions</label>
                  <textarea name="healthConditions" class="form-control form-control-sm" rows="1" placeholder="e.g. Asthma, none"></textarea>
                </div>
                <div class="mb-2">
                  <label class="form-label fw-medium small">Profile Photo</label>
                  <input type="file" name="profileImage" class="form-control form-control-sm" accept=".jpg,.jpeg,.png">
                </div>

            <button type="submit" class="btn btn-warning w-100 fw-bold rounded-3 mt-2">Create Account <i class="bi bi-arrow-right ms-2"></i></button>
          </form>

          <p class="text-center mt-2 mb-0 small">Already have an account? <a href="/login" class="fw-bold text-warning text-decoration-none">Login</a></p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('input[name="roleRadio"]').forEach(radio => {
  radio.addEventListener('change', function() {
    document.getElementById('roleInput').value = this.value;
    document.getElementById('coachFields').style.display = this.value === 'coach' ? 'block' : 'none';
    document.getElementById('memberFields').style.display = this.value === 'member' ? 'block' : 'none';
  });
});
(function() {
  var sel = document.getElementById('regDistrict');
  allDistricts.forEach(function(d) { sel.innerHTML += '<option value="' + d + '">' + d + '</option>'; });
})();
</script>

<%- include('partials/footer') %>
