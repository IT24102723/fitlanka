<%- include('partials/header') %>

<div class="container py-4">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Home</a></li>
      <li class="breadcrumb-item"><a href="/coaches" class="text-decoration-none">Coaches</a></li>
      <li class="breadcrumb-item active"><%= coach.name %></li>
    </ol>
  </nav>

  <div class="row g-4">
    <div class="col-lg-4">
      <div class="card shadow border-0 rounded-4 text-center p-4 sticky-lg-top" style="top:20px;">
        <div style="width:150px;height:150px;margin:0 auto;" class="mb-3">
          <img src="<%= coach.profileImage || 'https://images.unsplash.com/photo-1567013127542-490d757e51fc?w=300&h=300&fit=crop&crop=face' %>"
               alt="<%= coach.name %>"
               class="rounded-circle shadow"
               style="width:150px;height:150px;object-fit:cover;">
        </div>
        <h3 class="fw-bold"><%= coach.name %></h3>
        <span class="badge bg-warning text-dark fs-6 px-3 mb-3">Rs.<%= coach.coachDetails?.ratePerMonth || 2000 %> / month</span>
        <hr>
        <p class="mb-1 small"><i class="bi bi-envelope text-warning me-1"></i> <%= coach.email %></p>
        <p class="mb-1 small"><i class="bi bi-telephone text-warning me-1"></i> <%= coach.phone %></p>
        <p class="mb-0 small"><i class="bi bi-geo-alt text-warning me-1"></i> <%= [coach.city, coach.district].filter(Boolean).join(', ') || 'Sri Lanka' %></p>

        <hr>
        <% if (!user) { %>
          <a href="/register" class="btn btn-warning w-100 fw-bold rounded-3 mb-2">Register to Book</a>
          <a href="/login" class="btn btn-outline-warning w-100 rounded-3">Login</a>
        <% } else if (user.role === 'member') { %>
          <a href="/member/select-coach/<%= coach._id %>" class="btn btn-warning w-100 fw-bold rounded-3">
            <i class="bi bi-hand-index-thumb me-1"></i> Book This Coach
          </a>
        <% } else { %>
          <p class="text-muted small">Login as a member to book this coach.</p>
        <% } %>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card shadow border-0 rounded-4 mb-4">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-3"><i class="bi bi-person-vcard text-warning me-2"></i> About</h4>
          <p class="text-muted"><%= coach.coachDetails?.bio || 'No bio available.' %></p>
        </div>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-md-4">
          <div class="card shadow border-0 rounded-4 text-center p-3">
            <div class="fs-1 text-warning"><i class="bi bi-clock-history"></i></div>
            <h5 class="fw-bold mt-2"><%= coach.coachDetails?.experience || '0' %>+</h5>
            <p class="text-muted small">Years Experience</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow border-0 rounded-4 text-center p-3">
            <div class="fs-1 text-warning"><i class="bi bi-star"></i></div>
            <h5 class="fw-bold mt-2"><%= (coach.coachDetails?.specialties || []).length %></h5>
            <p class="text-muted small">Specialties</p>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card shadow border-0 rounded-4 text-center p-3">
            <div class="fs-1 text-warning"><i class="bi bi-people"></i></div>
            <h5 class="fw-bold mt-2" id="memberCount">-</h5>
            <p class="text-muted small">Active Members</p>
          </div>
        </div>
      </div>

      <div class="card shadow border-0 rounded-4 mb-4">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-3"><i class="bi bi-award text-warning me-2"></i> Specialties</h4>
          <% if (coach.coachDetails?.specialties && coach.coachDetails.specialties.length > 0) { %>
            <% coach.coachDetails.specialties.forEach(s => { %>
              <span class="badge bg-warning text-dark me-1 mb-1 px-3 py-2"><%= s %></span>
            <% }) %>
          <% } else { %>
            <p class="text-muted">No specialties listed.</p>
          <% } %>
        </div>
      </div>

      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">
          <h4 class="fw-bold mb-3"><i class="bi bi-file-earmark-text text-warning me-2"></i> Certificates</h4>
          <% if (coach.coachDetails?.certificates && coach.coachDetails.certificates.length > 0) { %>
            <ul class="list-group list-group-flush">
              <% coach.coachDetails.certificates.forEach(cert => { %>
                <li class="list-group-item d-flex align-items-center px-0">
                  <i class="bi bi-patch-check-fill text-success me-2"></i>
                  <span><%= cert.name %></span>
                </li>
              <% }) %>
            </ul>
          <% } else { %>
            <p class="text-muted">No certificates uploaded.</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
fetch('/coach-profile/<%= coach._id %>/members-count')
  .then(r => r.json())
  .then(d => document.getElementById('memberCount').textContent = d.count)
  .catch(() => document.getElementById('memberCount').textContent = '0');
</script>

<%- include('partials/footer') %>