<%- include('partials/header') %>

<div class="container py-5">
  <div class="row justify-content-center min-vh-75 align-items-center">
    <div class="col-lg-10">
      <div class="row align-items-center g-0 shadow-lg rounded-4 overflow-hidden">
        <div class="col-md-6 d-none d-md-block" style="min-height:500px;background:url('https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=800&h=600&fit=crop') center center / cover no-repeat;">
          <div class="p-5 d-flex flex-column justify-content-center h-100" style="background:linear-gradient(135deg,rgba(15,12,41,0.8),rgba(48,43,99,0.6));">
            <h2 class="text-white fw-bold display-6">Welcome Back!</h2>
            <p class="text-white-50">Continue your fitness journey with FitLanka. Login to access your dashboard.</p>
            <div class="mt-3">
              <div class="text-white mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Track your progress</div>
              <div class="text-white mb-2"><i class="bi bi-check-circle-fill text-warning me-2"></i> Connect with coaches</div>
              <div class="text-white"><i class="bi bi-check-circle-fill text-warning me-2"></i> Achieve your goals</div>
            </div>
          </div>
        </div>
        <div class="col-md-6 bg-white p-5">
          <div class="text-center mb-4">
            <div class="bg-warning bg-opacity-10 d-inline-flex p-3 rounded-circle mb-3">
              <i class="bi bi-box-arrow-in-right fs-1 text-warning"></i>
            </div>
            <h3 class="fw-bold">Welcome Back</h3>
            <p class="text-muted">Login to your FitLanka account</p>
          </div>
          <form action="/login" method="POST">
            <div class="mb-3">
              <label class="form-label fw-medium">Email Address</label>
              <div class="input-group">
                <span class="input-group-text bg-light"><i class="bi bi-envelope"></i></span>
                <input type="email" name="email" class="form-control form-control-lg" placeholder="you@example.com" required>
              </div>
            </div>
            <div class="mb-4">
              <label class="form-label fw-medium">Password</label>
              <div class="input-group">
                <span class="input-group-text bg-light"><i class="bi bi-lock"></i></span>
                <input type="password" name="password" class="form-control form-control-lg" placeholder="Enter your password" required>
              </div>
            </div>
            <button type="submit" class="btn btn-warning w-100 btn-lg fw-bold rounded-3">Login <i class="bi bi-arrow-right ms-2"></i></button>
          </form>
          <p class="text-center mt-4 mb-0">Don't have an account? <a href="/register" class="fw-bold text-warning text-decoration-none">Register here</a></p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
