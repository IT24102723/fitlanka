<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center mb-4">
    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3">
      <i class="bi bi-person-badge fs-2 text-warning"></i>
    </div>
    <div>
      <h2 class="fw-bold mb-0">Available Coaches</h2>
      <p class="text-muted mb-0">Find the perfect coach for your fitness goals</p>
    </div>
  </div>
  <div class="row g-4">
    <% coaches.forEach((c, index) => { %>
      <div class="col-md-4">
        <div class="card shadow-sm border-0 rounded-4 h-100 overflow-hidden">
          <div style="height:180px;overflow:hidden;background:linear-gradient(135deg,#0f0c29,#302b63);">
            <img src="<%= c.profileImage || 'https://images.unsplash.com/photo-1567013127542-490d757e51fc?w=400&h=200&fit=crop' %>" alt="<%= c.name %>" style="width:100%;height:100%;object-fit:cover;opacity:0.8;">
          </div>
          <div class="card-body text-center p-4" style="margin-top:-50px;">
            <div style="width:80px;height:80px;margin:0 auto;" class="mb-2">
              <img src="<%= c.profileImage || 'https://images.unsplash.com/photo-1633332755192-727a05c4013d?w=80&h=80&fit=crop&crop=face' %>" alt="<%= c.name %>" style="width:80px;height:80px;object-fit:cover;border:4px solid #fff;" class="rounded-circle shadow">
            </div>
            <h4 class="fw-bold"><%= c.name %></h4>
            <span class="badge bg-warning text-dark mb-3">Rs.<%= c.coachDetails?.ratePerMonth || 2000 %> / month</span>
            <hr>
            <div class="text-start small">
              <p class="mb-1"><i class="bi bi-clock-history text-warning me-1"></i> <strong>Experience:</strong> <%= c.coachDetails?.experience || '-' %> years</p>
              <p class="mb-1"><i class="bi bi-star text-warning me-1"></i> <strong>Specialties:</strong> <%= (c.coachDetails?.specialties || []).join(', ') || 'General' %></p>
              <p class="text-muted mt-2 mb-0"><%= (c.coachDetails?.bio || '').substring(0, 100) %></p>
            </div>
            <a href="/member/select-coach/<%= c._id %>" class="btn btn-warning w-100 fw-bold mt-3 rounded-3">
              <i class="bi bi-hand-index-thumb"></i> Select This Coach
            </a>
          </div>
        </div>
      </div>
    <% }) %>
    <% if (coaches.length === 0) { %>
      <div class="col-12 text-center py-5">
        <div class="display-2 mb-3 text-muted"><i class="bi bi-emoji-frown"></i></div>
        <h3 class="fw-bold">No Coaches Available Yet</h3>
        <p class="text-muted">Check back later or contact admin.</p>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
