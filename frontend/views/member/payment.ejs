<%- include('../partials/header') %>

<style>
  .card-preview { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: #fff; border-radius: 16px; padding: 24px; font-family: 'Courier New', monospace; min-height: 180px; transition: all 0.3s; }
  .card-preview .chip { width: 40px; height: 30px; background: #ffd700; border-radius: 6px; margin-bottom: 20px; }
  .card-preview .preview-number { font-size: 1.4rem; letter-spacing: 3px; word-spacing: 8px; margin-bottom: 15px; min-height: 32px; }
  .card-preview .preview-details { display: flex; gap: 40px; font-size: 0.75rem; }
  .card-preview .preview-details span { opacity: 0.6; }
  .card-preview .preview-details strong { font-size: 0.95rem; }
  .card-preview .card-type-badge { position: absolute; top: 20px; right: 24px; font-size: 1.5rem; opacity: 0.8; }
</style>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <div class="bg-warning bg-opacity-10 d-inline-flex p-3 rounded-circle mb-3">
              <i class="bi bi-credit-card fs-1 text-warning"></i>
            </div>
            <h3 class="fw-bold">Complete Payment</h3>
            <p class="text-muted">Book your membership with <%= coach.name %></p>
          </div>

          <div class="bg-light rounded-4 p-4 mb-4">
            <div class="d-flex align-items-center mb-3">
              <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-2">
                <i class="bi bi-person-badge text-warning fs-4"></i>
              </div>
              <h5 class="fw-bold mb-0"><%= coach.name %></h5>
            </div>
            <hr>
            <div class="d-flex justify-content-between mb-2">
              <span>Coach Fee (monthly)</span>
              <span class="fw-medium">Rs. <%= fee %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Website Fee</span>
              <span class="fw-medium">Rs. <%= websiteFee %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-5">
              <span>Total</span>
              <span class="text-warning" id="totalAmount">Rs. <%= total %></span>
            </div>
          </div>

          <div class="mb-4">
            <label class="fw-medium mb-2">Membership Duration</label>
            <div class="btn-group w-100" role="group">
              <% durations.forEach(function(m) { %>
                <input type="radio" class="btn-check" name="durationRadio" id="dur<%= m %>" value="<%= m %>" <%= m === 1 ? 'checked' : '' %>>
                <label class="btn btn-outline-warning px-3" for="dur<%= m %>"><%= m %> <%= m === 1 ? 'Month' : 'Months' %></label>
              <% }) %>
            </div>
            <input type="hidden" id="membershipDuration" value="1">
            <p class="small text-muted mt-1 mb-0">Total = <span id="durMonths">1</span> month(s) &times; Rs. <%= fee %> + Rs. <%= websiteFee %> fee</p>
          </div>

          <% if (payment.manualRef) { %>
            <div class="alert alert-success rounded-4 border-0 d-flex align-items-center">
              <i class="bi bi-check-circle-fill fs-4 me-3"></i>
              <div><strong>Payment submitted!</strong><br>Reference: <strong><%= payment.manualRef %></strong><br>Waiting for admin confirmation.</div>
            </div>
            <a href="/member/dashboard" class="btn btn-outline-secondary w-100 btn-lg rounded-3">Back to Dashboard</a>
          <% } else { %>

            <div id="paymentSuccess" class="d-none">
              <div class="text-center py-4">
                <div class="bg-success bg-opacity-10 d-inline-flex p-4 rounded-circle mb-3">
                  <i class="bi bi-check-circle-fill text-success fs-1"></i>
                </div>
                <h4 class="fw-bold">Payment Successful!</h4>
                <p class="text-muted mb-0">Your membership with <strong><%= coach.name %></strong> is now active.</p>
                <p class="text-muted">Check your dashboard for coach contact details.</p>
                <a href="/member/dashboard" class="btn btn-success btn-lg fw-bold rounded-pill px-5 mt-3">Go to Dashboard</a>
              </div>
            </div>

            <form id="cardPaymentForm">
              <!-- Card Preview -->
              <div class="position-relative mb-3">
                <div class="card-preview" id="cardPreview">
                  <div class="d-flex justify-content-between align-items-start">
                    <div class="chip"></div>
                    <div class="card-type-badge" id="cardTypeIcon">💳</div>
                  </div>
                  <div class="preview-number" id="previewNumber">4916 1000 0000 0000</div>
                  <div class="preview-details">
                    <div><span>CARDHOLDER</span><br><strong id="previewName"><%= member.name.toUpperCase() %></strong></div>
                    <div><span>EXPIRY</span><br><strong id="previewExpiry">12/28</strong></div>
                    <div><span>CVV</span><br><strong id="previewCvv">123</strong></div>
                  </div>
                </div>
              </div>

              <div class="mb-3">
                <label class="fw-medium mb-1 small">Card Type</label>
                <select class="form-select rounded-3" id="cardType" required>
                  <option value="visa">Visa</option>
                  <option value="mastercard">Mastercard</option>
                  <option value="amex">American Express</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="fw-medium mb-1 small">Card Number</label>
                <input type="text" class="form-control form-control-lg rounded-3" id="cardNumber" placeholder="4916 1000 0000 0000" maxlength="19" required>
              </div>

              <div class="row mb-3">
                <div class="col-6">
                  <label class="fw-medium mb-1 small">Expiry Date</label>
                  <input type="text" class="form-control rounded-3" id="expiry" placeholder="MM/YY" maxlength="5" required>
                </div>
                <div class="col-6">
                  <label class="fw-medium mb-1 small">CVV</label>
                  <input type="text" class="form-control rounded-3" id="cvv" placeholder="123" maxlength="4" required>
                </div>
              </div>

              <div class="mb-3">
                <label class="fw-medium mb-1 small">Cardholder Name</label>
                <input type="text" class="form-control rounded-3" id="cardName" value="<%= member.name %>" required>
              </div>

              <button type="submit" class="btn btn-warning w-100 btn-lg fw-bold rounded-3 shadow-lg" id="payBtn">
                <span id="payBtnText">Pay Rs. <%= total %></span>
                <span id="payBtnSpinner" class="spinner-border spinner-border-sm d-none me-2"></span>
              </button>
              <div class="text-center mt-2">
                <a href="/member/cancel" class="btn btn-sm btn-outline-secondary rounded-pill px-4" onclick="return confirm('Cancel payment?')"><i class="bi bi-x-circle me-1"></i> Cancel</a>
              </div>
            </form>

            <hr class="my-3">

            <div class="accordion" id="bankAccordion">
              <div class="accordion-item border-0">
                <h2 class="accordion-header">
                  <button class="accordion-button collapsed bg-light fw-medium rounded-3" type="button" data-bs-toggle="collapse" data-bs-target="#bankDetails">
                    <i class="bi bi-bank me-2"></i> Pay via Bank Transfer
                  </button>
                </h2>
                <div id="bankDetails" class="accordion-collapse collapse" data-bs-parent="#bankAccordion">
                  <div class="accordion-body px-0">
                    <table class="table table-borderless mb-3 small">
                      <tr><td class="text-muted ps-0">Bank:</td><td class="fw-bold text-end"><%= bank.bankName %></td></tr>
                      <tr><td class="text-muted ps-0">Account Name:</td><td class="fw-bold text-end"><%= bank.accountName %></td></tr>
                      <tr><td class="text-muted ps-0">Account Number:</td><td class="fw-bold text-end" style="font-size:1.1rem"><%= bank.accountNumber %></td></tr>
                      <tr><td class="text-muted ps-0">Branch:</td><td class="fw-bold text-end"><%= bank.branch %></td></tr>
                    </table>
                    <form method="post" action="/member/confirm-payment">
                      <input type="hidden" name="paymentId" value="<%= payment._id %>">
                      <input type="hidden" name="membershipDuration" id="bankDuration" value="1">
                      <input type="text" name="manualRef" class="form-control rounded-3 mb-2" placeholder="Bank Reference" required>
                      <button type="submit" class="btn btn-outline-success w-100 rounded-3">Submit Bank Transfer</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>

          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
var feePerMonth = <%= fee %>;
var websiteFee = <%= websiteFee %>;

function updateTotal() {
  var dur = parseInt(document.querySelector('input[name="durationRadio"]:checked').value) || 1;
  var total = feePerMonth * dur + websiteFee;
  document.getElementById('totalAmount').textContent = 'Rs. ' + total;
  document.getElementById('membershipDuration').value = dur;
  document.getElementById('bankDuration').value = dur;
  document.getElementById('durMonths').textContent = dur;
  document.getElementById('payBtnText').textContent = 'Pay Rs. ' + total;
}

document.querySelectorAll('input[name="durationRadio"]').forEach(function(radio) {
  radio.addEventListener('change', updateTotal);
});

document.getElementById('cardNumber').addEventListener('input', function(e) {
  let val = this.value.replace(/\D/g, '').substring(0, 16);
  let formatted = val.replace(/(.{4})/g, '$1 ').trim();
  this.value = formatted;
  document.getElementById('previewNumber').textContent = formatted || '4916 1000 0000 0000';
});

document.getElementById('expiry').addEventListener('input', function(e) {
  let val = this.value.replace(/\D/g, '').substring(0, 4);
  if (val.length > 2) val = val.substring(0, 2) + '/' + val.substring(2);
  this.value = val;
  document.getElementById('previewExpiry').textContent = val || '12/28';
});

document.getElementById('cvv').addEventListener('input', function(e) {
  this.value = this.value.replace(/\D/g, '').substring(0, 4);
  document.getElementById('previewCvv').textContent = this.value || '123';
});

document.getElementById('cardName').addEventListener('input', function(e) {
  document.getElementById('previewName').textContent = this.value.toUpperCase() || '<%= member.name.toUpperCase() %>';
});

document.getElementById('cardType').addEventListener('input', function() {
  const icons = { visa: '💳', mastercard: '💳', amex: '💳' };
  document.getElementById('cardTypeIcon').textContent = icons[this.value] || '💳';
});

document.getElementById('cardPaymentForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var dur = parseInt(document.querySelector('input[name="durationRadio"]:checked').value) || 1;
  const btn = document.getElementById('payBtn');
  const text = document.getElementById('payBtnText');
  const spinner = document.getElementById('payBtnSpinner');
  btn.disabled = true;
  text.textContent = 'Processing...';
  spinner.classList.remove('d-none');

  setTimeout(function() {
    fetch('/member/demo-pay/<%= payment._id %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: 'membershipDuration=' + dur
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          document.getElementById('cardPaymentForm').classList.add('d-none');
          document.getElementById('paymentSuccess').classList.remove('d-none');
        } else {
          alert('Payment failed. Please try again.');
          btn.disabled = false;
          var t = feePerMonth * dur + websiteFee;
          text.textContent = 'Pay Rs. ' + t;
          spinner.classList.add('d-none');
        }
      })
      .catch(function() {
        alert('Error processing payment.');
        btn.disabled = false;
        var t = feePerMonth * dur + websiteFee;
        text.textContent = 'Pay Rs. ' + t;
        spinner.classList.add('d-none');
      });
  }, 2000);
});
</script>

<%- include('../partials/footer') %>
