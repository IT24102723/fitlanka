<%- include('../partials/header') %>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <div class="bg-warning bg-opacity-10 d-inline-flex p-3 rounded-circle mb-3">
              <i class="bi bi-credit-card fs-1 text-warning"></i>
            </div>
            <h3 class="fw-bold">Complete Payment</h3>
            <p class="text-muted">Secure your membership with <%= coach.name %></p>
          </div>

          <div class="bg-light rounded-4 p-4 mb-4">
            <div class="d-flex align-items-center mb-3">
              <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-2">
                <i class="bi bi-person-badge text-warning fs-4"></i>
              </div>
              <h5 class="fw-bold mb-0"><%= coach.name %></h5>
            </div>
            <hr>
            <div class="d-flex justify-content-between mb-2">
              <span>Coach Fee (monthly)</span>
              <span class="fw-medium">Rs. <%= fee %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Website Fee</span>
              <span class="fw-medium">Rs. <%= websiteFee %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-5">
              <span>Total</span>
              <span class="text-warning">Rs. <%= total %></span>
            </div>
          </div>

          <div class="text-center mb-4">
            <img src="https://www.payhere.lk/images/payhere-logo-white.png" alt="PayHere" class="img-fluid rounded-2" style="max-height:44px;background:#000;padding:10px 20px;">
            <p class="text-muted small mt-2">Verified by PayHere &mdash; Sri Lanka's Payment Gateway</p>
          </div>

          <button id="payhere-button" class="btn btn-warning w-100 btn-lg fw-bold rounded-3 shadow-lg">
            <i class="bi bi-lock-fill me-2"></i> Pay Rs. <%= total %> Now
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function initPayHere(cb) {
  if (typeof PayHere !== 'undefined' && PayHere.checkout) { cb(); return; }
  var s = document.createElement('script');
  s.src = 'https://www.payhere.lk/lib/payhere.js';
  s.onload = cb;
  document.head.appendChild(s);
}

document.getElementById('payhere-button').addEventListener('click', function() {
  var btn = this; btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Loading...';
  initPayHere(function() {
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-lock-fill me-2"></i> Pay Rs. <%= total %> Now';
    var payment = {
      sandbox: <%= process.env.PAYHERE_SANDBOX === 'true' ? 'true' : 'false' %>,
      merchant_id: '<%= payhereMerchantId %>',
      return_url: window.location.origin + '/member/success',
      cancel_url: window.location.origin + '/member/cancel',
      notify_url: window.location.origin + '/payment/notify',
      order_id: '<%= orderId %>',
      items: 'Coach: <%= coach.name %> - Monthly Membership',
      amount: '<%= total %>',
      currency: '<%= currency %>',
      first_name: '<%= member.name.split(" ")[0] %>',
      last_name: '<%= member.name.split(" ").slice(1).join(" ") || "N/A" %>',
      email: '<%= member.email %>',
      phone: '<%= member.phone %>',
      address: 'Colombo',
      city: 'Colombo',
      country: 'Sri Lanka',
      hash: '<%= hash %>'
    };
    PayHere.checkout(payment);
  });
});
</script>

<%- include('../partials/footer') %>
