<%- include('../partials/header') %>

<style>
  .payment-tab { cursor: pointer; padding: 12px; border-radius: 12px; transition: all 0.2s; border: 2px solid transparent; }
  .payment-tab:hover { background: #f8f9fa; }
  .payment-tab.active { border-color: #ffc107; background: #fff9e6; }
  .payment-tab input[type="radio"] { display: none; }
  .payment-option { display: none; }
  .payment-option.active { display: block; }
</style>

<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
          <div class="text-center mb-4">
            <div class="bg-warning bg-opacity-10 d-inline-flex p-3 rounded-circle mb-3">
              <i class="bi bi-credit-card fs-1 text-warning"></i>
            </div>
            <h3 class="fw-bold">Complete Payment</h3>
            <p class="text-muted">Secure your membership with <%= coach.name %></p>
          </div>

          <div class="bg-light rounded-4 p-4 mb-4">
            <div class="d-flex align-items-center mb-3">
              <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-2">
                <i class="bi bi-person-badge text-warning fs-4"></i>
              </div>
              <h5 class="fw-bold mb-0"><%= coach.name %></h5>
            </div>
            <hr>
            <div class="d-flex justify-content-between mb-2">
              <span>Coach Fee (monthly)</span>
              <span class="fw-medium">Rs. <%= fee %></span>
            </div>
            <div class="d-flex justify-content-between mb-2">
              <span>Website Fee</span>
              <span class="fw-medium">Rs. <%= websiteFee %></span>
            </div>
            <hr>
            <div class="d-flex justify-content-between fw-bold fs-5">
              <span>Total</span>
              <span class="text-warning">Rs. <%= total %></span>
            </div>
          </div>

          <div class="row g-2 mb-4">
            <div class="col-6">
              <label class="payment-tab active d-block text-center" onclick="switchPayment('payhere')">
                <input type="radio" name="payMethod" value="payhere" checked>
                <i class="bi bi-credit-card-2-front fs-2 d-block mb-1 text-warning"></i>
                <span class="fw-bold small">Pay Online</span>
                <span class="d-block text-muted" style="font-size:11px">Visa / Mastercard</span>
              </label>
            </div>
            <div class="col-6">
              <label class="payment-tab d-block text-center" onclick="switchPayment('manual')">
                <input type="radio" name="payMethod" value="manual">
                <i class="bi bi-bank fs-2 d-block mb-1 text-success"></i>
                <span class="fw-bold small">Bank Transfer</span>
                <span class="d-block text-muted" style="font-size:11px">Manual payment</span>
              </label>
            </div>
          </div>

          <% if (payment.manualRef) { %>
            <div class="alert alert-success rounded-4 border-0 d-flex align-items-center">
              <i class="bi bi-check-circle-fill fs-4 me-3"></i>
              <div><strong>Payment submitted!</strong><br>Reference: <strong><%= payment.manualRef %></strong><br>Waiting for admin confirmation.</div>
            </div>
            <a href="/member/dashboard" class="btn btn-outline-secondary w-100 btn-lg rounded-3">Back to Dashboard</a>
          <% } else { %>

            <!-- PayHere Card Payment -->
            <div id="payhere-option" class="payment-option active">
              <div class="text-center mb-3">
                <img src="https://www.payhere.lk/images/payhere-logo-white.png" alt="PayHere" class="img-fluid rounded-2" style="max-height:40px;background:#000;padding:8px 16px;">
                <p class="text-muted small mt-1">Pay securely via PayHere</p>
              </div>
              <form id="payhere-form" method="post" action="<%= checkoutUrl %>">
                <input type="hidden" name="merchant_id" value="<%= payhereMerchantId %>">
                <input type="hidden" name="return_url" value="<%= returnUrl %>">
                <input type="hidden" name="cancel_url" value="<%= cancelUrl %>">
                <input type="hidden" name="notify_url" value="<%= notifyUrl %>">
                <input type="hidden" name="order_id" value="<%= orderId %>">
                <input type="hidden" name="items" value="Coach: <%= coach.name %> - Monthly Membership">
                <input type="hidden" name="currency" value="<%= currency %>">
                <input type="hidden" name="amount" value="<%= total.toFixed(2) %>">
                <input type="hidden" name="first_name" value="<%= member.name.split(' ')[0] %>">
                <input type="hidden" name="last_name" value="<%= member.name.split(' ').slice(1).join(' ') || 'N/A' %>">
                <input type="hidden" name="email" value="<%= member.email %>">
                <input type="hidden" name="phone" value="<%= member.phone %>">
                <input type="hidden" name="address" value="Colombo">
                <input type="hidden" name="city" value="Colombo">
                <input type="hidden" name="country" value="Sri Lanka">
                <input type="hidden" name="hash" value="<%= hash %>">
                <button type="submit" class="btn btn-warning w-100 btn-lg fw-bold rounded-3 shadow-lg">
                  <i class="bi bi-lock-fill me-2"></i> Pay Rs. <%= total %> Now
                </button>
              </form>
              <div class="text-center mt-2">
                <small class="text-muted">
                  <i class="bi bi-shield-check"></i> Test card: 4916 1000 0000 0000
                </small>
              </div>
            </div>

            <!-- Manual Bank Transfer -->
            <div id="manual-option" class="payment-option">
              <div class="card border-success border-2 rounded-4 mb-3">
                <div class="card-body p-3">
                  <div class="text-center mb-2">
                    <i class="bi bi-building fs-1 text-success"></i>
                    <h6 class="fw-bold mt-1">Bank Transfer Details</h6>
                  </div>
                  <table class="table table-borderless mb-0 small">
                    <tr><td class="text-muted ps-0">Bank:</td><td class="fw-bold text-end"><%= bank.bankName %></td></tr>
                    <tr><td class="text-muted ps-0">Account Name:</td><td class="fw-bold text-end"><%= bank.accountName %></td></tr>
                    <tr><td class="text-muted ps-0">Account No:</td><td class="fw-bold text-end" style="font-size:1.1rem"><%= bank.accountNumber %></td></tr>
                    <tr><td class="text-muted ps-0">Branch:</td><td class="fw-bold text-end"><%= bank.branch %></td></tr>
                  </table>
                </div>
              </div>
              <form method="post" action="/member/confirm-payment">
                <input type="hidden" name="paymentId" value="<%= payment._id %>">
                <div class="mb-3">
                  <label class="fw-medium mb-2 small">Bank Transaction Reference</label>
                  <input type="text" name="manualRef" class="form-control rounded-3" placeholder="e.g. BOC25032024001" required>
                </div>
                <button type="submit" class="btn btn-success w-100 btn-lg fw-bold rounded-3 shadow-lg">
                  <i class="bi bi-check-lg me-2"></i> I've Completed the Transfer
                </button>
              </form>
            </div>

          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function switchPayment(method) {
  document.querySelectorAll('.payment-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('active'));
  document.querySelector(`.payment-tab input[value="${method}"]`).closest('.payment-tab').classList.add('active');
  document.getElementById(method + '-option').classList.add('active');
}
</script>

<%- include('../partials/footer') %>
