<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center mb-4">
    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3">
      <i class="bi bi-person fs-2 text-warning"></i>
    </div>
    <div>
      <h2 class="fw-bold mb-0">My Dashboard</h2>
      <p class="text-muted mb-0">Welcome back, <%= member.name %>!</p>
    </div>
  </div>
  <div class="row">
    <div class="col-md-4">
      <div class="card shadow border-0 rounded-4 mb-4 text-center p-4">
        <div class="bg-warning bg-opacity-10 d-inline-flex p-3 rounded-circle mx-auto mb-3">
          <i class="bi bi-person-circle fs-1 text-warning"></i>
        </div>
        <h4 class="fw-bold"><%= member.name %></h4>
        <span class="badge bg-<%= member.status === 'approved' ? 'success' : 'warning' %> fs-6 px-3"><%= member.status %></span>
        <hr>
        <p class="mb-1 small"><i class="bi bi-envelope"></i> <%= member.email %></p>
        <p class="mb-0 small"><i class="bi bi-telephone"></i> <%= member.phone %></p>
      </div>
    </div>
    <div class="col-md-8">
      <% if (member.status === 'pending') { %>
        <div class="alert alert-warning rounded-4 border-0 shadow-sm d-flex align-items-center">
          <i class="bi bi-hourglass-split fs-3 me-3"></i>
          <div><strong>Account Pending Approval</strong><br>Your account is under review. You'll be able to select a coach once approved.</div>
        </div>
      <% } else if (member.status === 'rejected') { %>
        <div class="alert alert-danger rounded-4 border-0 shadow-sm">
          <i class="bi bi-x-circle me-2"></i> Your account has been rejected. Please contact admin.
        </div>
      <% } else if (completedPayment) { %>
        <% 
          var now = new Date();
          var expiry = completedPayment.expiryDate ? new Date(completedPayment.expiryDate) : null;
          var isExpired = expiry && expiry < now;
        %>
        <div class="card shadow border-0 rounded-4 mb-3">
          <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                  <% if (completedPayment.coach && completedPayment.coach.profileImage) { %>
                    <img src="<%= completedPayment.coach.profileImage %>" style="width:40px;height:40px;object-fit:cover;" class="rounded-circle me-2 shadow-sm">
                  <% } else { %>
                    <div class="<%= isExpired ? 'bg-danger bg-opacity-10' : 'bg-success bg-opacity-10' %> p-2 rounded-3 me-2"><i class="bi <%= isExpired ? 'bi-clock-history text-danger' : 'bi-check-circle-fill text-success' %> fs-4"></i></div>
                  <% } %>
                  <h5 class="fw-bold mb-0"><%= isExpired ? 'Membership Expired' : 'Membership Active' %></h5>
                  <span class="badge <%= isExpired ? 'bg-danger' : 'bg-success' %> ms-2 fs-6 px-3"><%= completedPayment.membershipDuration || 1 %> Month<%= (completedPayment.membershipDuration || 1) > 1 ? 's' : '' %></span>
            </div>
            <div class="row">
              <div class="col-md-7">
                <p class="mb-1"><strong>Coach:</strong> <%= completedPayment.coach?.name || 'N/A' %></p>
                <p class="mb-1"><strong>Paid:</strong> Rs.<%= completedPayment.totalAmount %></p>
                <p class="mb-1"><strong>Started:</strong> <%= new Date(completedPayment.createdAt).toLocaleDateString() %></p>
                <p class="mb-0"><strong>Valid Until:</strong> <%= expiry ? expiry.toLocaleDateString() : 'N/A' %></p>
              </div>
              <% if (!isExpired) { %>
              <div class="col-md-5">
                <div class="bg-light rounded-3 p-3">
                  <h6 class="fw-bold text-warning mb-2"><i class="bi bi-telephone"></i> Coach Contact</h6>
                  <p class="mb-1"><i class="bi bi-envelope me-1"></i> <%= member.selectedCoach?.email || 'N/A' %></p>
                  <p class="mb-0"><i class="bi bi-telephone me-1"></i> <%= member.selectedCoach?.phone || 'N/A' %></p>
                </div>
              </div>
              <% } %>
            </div>
            <% if (isExpired) { %>
              <div class="alert alert-danger py-2 mt-2 mb-0 small">
                <i class="bi bi-exclamation-triangle me-1"></i> Your membership has expired. 
                <a href="/member/select-coach/<%= member.selectedCoach?._id || completedPayment.coach?._id %>" class="alert-link">Renew now</a>
              </div>
            <% } %>
          </div>
        </div>
      <% } else if (pendingPayment && pendingPayment.manualRef) { %>
        <div class="card shadow border-0 rounded-4 mb-3">
          <div class="card-body p-4 text-center">
            <div class="display-3 mb-2"><i class="bi bi-clock-history text-warning"></i></div>
            <h4>Payment Awaiting Confirmation</h4>
            <p class="text-muted">Your bank transfer (ref: <strong><%= pendingPayment.manualRef %></strong>) is being reviewed. Admin will confirm within 24 hours.</p>
            <a href="/member/select-coach/<%= member.selectedCoach._id %>" class="btn btn-outline-warning btn-lg fw-bold rounded-pill px-4">View Payment Details</a>
          </div>
        </div>
      <% } else if (member.selectedCoach) { %>
        <div class="card shadow border-0 rounded-4 mb-3">
          <div class="card-body p-4 text-center">
            <div class="display-3 mb-2"><i class="bi bi-hand-index-thumb text-warning"></i></div>
            <h4>Coach Selected: <span class="text-warning"><%= member.selectedCoach?.name || 'N/A' %></span></h4>
            <p class="text-muted">Complete payment to unlock coach contact details.</p>
            <a href="/member/select-coach/<%= member.selectedCoach._id %>" class="btn btn-warning btn-lg fw-bold rounded-pill px-4">Pay Now</a>
          </div>
        </div>
      <% } else { %>
        <div class="card shadow border-0 rounded-4">
          <div class="card-body text-center py-5">
            <div class="display-2 mb-3"><i class="bi bi-search-heart text-warning"></i></div>
            <h3 class="fw-bold">Find Your Perfect Coach</h3>
            <p class="text-muted mb-4">Browse our certified coaches and start your fitness journey today.</p>
            <a href="/member/coaches" class="btn btn-warning btn-lg fw-bold rounded-pill px-5 shadow-lg">Browse Coaches</a>
          </div>
        </div>
      <% } %>

      <% if (completedPayment) { %>
        <div class="card shadow border-0 rounded-4 mt-3">
          <div class="card-body p-4">
            <div class="d-flex align-items-center mb-3">
              <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-2">
                <i class="bi bi-star text-warning fs-4"></i>
              </div>
              <h5 class="fw-bold mb-0">Rate Your Coach</h5>
            </div>
            <form id="dashFeedbackForm">
              <input type="hidden" name="name" value="<%= member.name %>">
              <input type="hidden" name="email" value="<%= member.email %>">
              <input type="hidden" name="type" value="coach">
              <div class="mb-2">
                <label class="fw-medium small">Select Coach</label>
                <select class="form-select rounded-3" name="coachId" required>
                  <option value="">Choose a coach...</option>
                  <% if (coaches && coaches.length) { %>
                    <% coaches.forEach(c => { %>
                      <option value="<%= c._id %>" <%= (completedPayment?.coach?._id && completedPayment.coach._id.toString() === c._id.toString()) ? 'selected' : '' %>><%= c.name %></option>
                    <% }) %>
                  <% } %>
                </select>
              </div>
              <div class="mb-2">
                <div class="star-rating-dash">
                  <i class="bi bi-star fs-4 text-warning" data-star="1"></i>
                  <i class="bi bi-star fs-4 text-warning" data-star="2"></i>
                  <i class="bi bi-star fs-4 text-warning" data-star="3"></i>
                  <i class="bi bi-star fs-4 text-warning" data-star="4"></i>
                  <i class="bi bi-star fs-4 text-warning" data-star="5"></i>
                  <input type="hidden" name="rating" value="5">
                </div>
              </div>
              <div class="mb-2">
                <textarea class="form-control rounded-3" name="message" rows="2" placeholder="Share your experience with <%= completedPayment.coach?.name || 'your coach' %>..." required></textarea>
              </div>
              <div id="dashFeedbackMsg"></div>
              <button type="submit" class="btn btn-warning rounded-pill px-4 fw-medium">Submit Feedback</button>
            </form>
          </div>
        </div>
      <% } %>

    </div>
  </div>
</div>

<script>
document.querySelectorAll('.star-rating-dash').forEach(el => {
  el.addEventListener('click', function(e) {
    if (e.target.tagName === 'I') {
      const val = e.target.dataset.star;
      this.querySelectorAll('i').forEach(i => {
        i.className = i.dataset.star <= val ? 'bi bi-star-fill fs-4 text-warning' : 'bi bi-star fs-4 text-warning';
      });
      this.querySelector('[name="rating"]').value = val;
    }
  });
});

document.getElementById('dashFeedbackForm')?.addEventListener('submit', function(e) {
  e.preventDefault();
  const data = Object.fromEntries(new FormData(this));
  fetch('/feedback', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(data) })
    .then(r => r.json()).then(d => {
      document.getElementById('dashFeedbackMsg').innerHTML = d.success
        ? '<div class="alert alert-success py-1 small">Thank you! Your feedback helps others.</div>'
        : '<div class="alert alert-danger py-1 small">' + (d.error || 'Failed') + '</div>';
      if (d.success) setTimeout(() => document.getElementById('dashFeedbackMsg').innerHTML = '', 3000);
    });
});
</script>

<%- include('../partials/footer') %>
