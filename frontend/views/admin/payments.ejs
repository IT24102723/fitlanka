<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
      <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
        <i class="bi bi-credit-card fs-2 text-success"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0">Completed Payments</h4>
        <p class="text-muted mb-0">All successful membership payments</p>
      </div>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline-secondary rounded-3">Back</a>
  </div>
  <div class="card shadow border-0 rounded-4">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr><th>Member</th><th>Coach</th><th>Coach Fee</th><th>Website Fee</th><th>Total</th><th>Date</th></tr>
          </thead>
          <tbody>
            <% payments.forEach(p => { %>
              <tr>
                <td class="fw-medium"><%= p.member?.name || 'N/A' %></td>
                <td><%= p.coach?.name || 'N/A' %></td>
                <td>Rs.<%= p.amount %></td>
                <td>Rs.<%= p.websiteFee %></td>
                <td class="fw-bold">Rs.<%= p.totalAmount %></td>
                <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
              </tr>
            <% }) %>
            <% if (payments.length === 0) { %>
              <tr><td colspan="6" class="text-center text-muted py-5"><i class="bi bi-cash-stack fs-2 d-block mb-2"></i>No payments yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
