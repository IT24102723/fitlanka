<%- include('../partials/header') %>

<style>
  .nav-tabs .nav-link { font-weight: 600; color: #6c757d; border: none; padding: 10px 20px; }
  .nav-tabs .nav-link.active { color: #198754; border-bottom: 3px solid #198754; background: transparent; }
  .nav-tabs .nav-link:hover { color: #198754; }
</style>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
      <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
        <i class="bi bi-credit-card fs-2 text-success"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0">Payments</h4>
        <p class="text-muted mb-0">Manage membership payments</p>
      </div>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline-secondary rounded-3">Back</a>
  </div>

  <ul class="nav nav-tabs mb-4" id="paymentTabs">
    <li class="nav-item"><a class="nav-link active" href="#pending" data-bs-toggle="tab">Pending <span class="badge bg-warning ms-1"><%= pendingCount %></span></a></li>
    <li class="nav-item"><a class="nav-link" href="#completed" data-bs-toggle="tab">Completed</a></li>
  </ul>

  <div class="tab-content">
    <div class="tab-pane fade show active" id="pending">
      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead><tr><th>Member</th><th>Coach</th><th>Total</th><th>Method</th><th>Reference</th><th>Date</th><th>Action</th></tr></thead>
              <tbody>
                <% pending.forEach(p => { %>
                  <tr>
                    <td class="fw-medium"><%= p.member?.name || 'N/A' %></td>
                    <td><%= p.coach?.name || 'N/A' %></td>
                    <td class="fw-bold">Rs.<%= p.totalAmount %></td>
                    <td><span class="badge bg-info"><%= p.paymentMethod %></span></td>
                    <td><code><%= p.manualRef || '-' %></code></td>
                    <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
                    <td>
                      <form method="post" action="/admin/payments/confirm/<%= p._id %>" style="display:inline">
                        <button class="btn btn-success btn-sm rounded-3 fw-medium" onclick="return confirm('Confirm this payment?')">
                          <i class="bi bi-check-lg"></i> Confirm
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
                <% if (pending.length === 0) { %>
                  <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-check-circle fs-2 d-block mb-2"></i>No pending payments</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <div class="tab-pane fade" id="completed">
      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead><tr><th>Member</th><th>Coach</th><th>Coach Fee</th><th>Website Fee</th><th>Total</th><th>Method</th><th>Date</th></tr></thead>
              <tbody>
                <% completed.forEach(p => { %>
                  <tr>
                    <td class="fw-medium"><%= p.member?.name || 'N/A' %></td>
                    <td><%= p.coach?.name || 'N/A' %></td>
                    <td>Rs.<%= p.amount %></td>
                    <td>Rs.<%= p.websiteFee %></td>
                    <td class="fw-bold">Rs.<%= p.totalAmount %></td>
                    <td><span class="badge bg-secondary"><%= p.paymentMethod %></span></td>
                    <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
                <% if (completed.length === 0) { %>
                  <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-cash-stack fs-2 d-block mb-2"></i>No completed payments</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
