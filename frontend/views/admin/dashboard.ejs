<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center mb-4">
    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3">
      <i class="bi bi-shield-lock fs-2 text-warning"></i>
    </div>
    <div>
      <h2 class="fw-bold mb-0">Admin Dashboard</h2>
      <p class="text-muted mb-0">Manage coaches, members, and payments</p>
    </div>
  </div>
  <div class="row g-4 mb-4">
    <div class="col-md-3">
      <div class="card bg-gradient-warning text-dark border-0 shadow rounded-4 h-100">
        <div class="card-body text-center p-4">
          <div class="display-3 fw-bold mb-1"><%= pendingCoaches %></div>
          <p class="mb-0 fw-medium"><i class="bi bi-person-badge"></i> Pending Coaches</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-gradient-info text-white border-0 shadow rounded-4 h-100">
        <div class="card-body text-center p-4">
          <div class="display-3 fw-bold mb-1"><%= pendingMembers %></div>
          <p class="mb-0 fw-medium"><i class="bi bi-people"></i> Pending Members</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-gradient-success text-white border-0 shadow rounded-4 h-100">
        <div class="card-body text-center p-4">
          <div class="display-3 fw-bold mb-1"><%= totalCoaches %></div>
          <p class="mb-0 fw-medium"><i class="bi bi-check-circle"></i> Approved Coaches</p>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card bg-gradient-primary text-white border-0 shadow rounded-4 h-100">
        <div class="card-body text-center p-4">
          <div class="display-3 fw-bold mb-1"><%= totalMembers %></div>
          <p class="mb-0 fw-medium"><i class="bi bi-person-check"></i> Approved Members</p>
        </div>
      </div>
    </div>
  </div>
  <div class="row g-3">
    <div class="col-md-4">
      <a href="/admin/coaches" class="btn btn-outline-warning w-100 py-3 fw-bold rounded-3"><i class="bi bi-people"></i> Manage Coaches</a>
    </div>
    <div class="col-md-4">
      <a href="/admin/members" class="btn btn-outline-info w-100 py-3 fw-bold rounded-3"><i class="bi bi-person-badge"></i> Manage Members</a>
    </div>
    <div class="col-md-4">
      <a href="/admin/payments" class="btn btn-outline-success w-100 py-3 fw-bold rounded-3"><i class="bi bi-credit-card"></i> View Payments</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
