<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
      <div class="bg-info bg-opacity-10 p-3 rounded-3 me-3">
        <i class="bi bi-person-badge fs-2 text-info"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0">All Members</h4>
        <p class="text-muted mb-0">Manage member registrations</p>
      </div>
    </div>
    <a href="/admin/dashboard" class="btn btn-outline-secondary rounded-3">Back</a>
  </div>
  <div class="card shadow border-0 rounded-4">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead>
            <tr><th>Name</th><th>Email</th><th>Phone</th><th>Age</th><th>Goals</th><th>Status</th><th>Action</th></tr>
          </thead>
          <tbody>
            <% members.forEach(m => { %>
              <tr>
                <td class="fw-medium"><%= m.name %></td>
                <td><%= m.email %></td>
                <td><%= m.phone %></td>
                <td><%= m.memberDetails?.age || '-' %></td>
                <td><%= (m.memberDetails?.fitnessGoals || '').substring(0, 30) || '-' %></td>
                <td>
                  <span class="badge bg-<%= m.status === 'approved' ? 'success' : m.status === 'pending' ? 'warning' : 'danger' %>">
                    <%= m.status %>
                  </span>
                </td>
                <td>
                  <% if (m.status === 'pending') { %>
                    <form action="/admin/approve/<%= m._id %>" method="POST" class="d-inline">
                      <button class="btn btn-sm btn-success rounded-3"><i class="bi bi-check-lg"></i></button>
                    </form>
                    <form action="/admin/reject/<%= m._id %>" method="POST" class="d-inline">
                      <button class="btn btn-sm btn-danger rounded-3"><i class="bi bi-x-lg"></i></button>
                    </form>
                  <% } else { %>
                    <span class="text-muted small">-</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
            <% if (members.length === 0) { %>
              <tr><td colspan="7" class="text-center text-muted py-5"><i class="bi bi-people fs-2 d-block mb-2"></i>No members registered yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
