<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
      <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3">
        <i class="bi bi-person-plus fs-2 text-success"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0">Add New <%= role.charAt(0).toUpperCase() + role.slice(1) %></h4>
        <p class="text-muted mb-0">Create a new user directly</p>
      </div>
    </div>
    <a href="/admin/<%= role %>s" class="btn btn-outline-secondary rounded-3">Back</a>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow border-0 rounded-4 p-4">
        <form action="/admin/users/add" method="POST">
          <input type="hidden" name="role" value="<%= role %>">

          <div class="d-flex gap-2 mb-4">
            <a href="/admin/users/add?role=coach" class="btn <%= role === 'coach' ? 'btn-warning' : 'btn-outline-warning' %> rounded-3 px-4">Coach</a>
            <a href="/admin/users/add?role=member" class="btn <%= role === 'member' ? 'btn-info' : 'btn-outline-info' %> rounded-3 px-4">Member</a>
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-medium">Full Name</label>
              <input type="text" name="name" class="form-control rounded-3" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Email</label>
              <input type="email" name="email" class="form-control rounded-3" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Phone</label>
              <input type="text" name="phone" class="form-control rounded-3" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Password</label>
              <input type="password" name="password" class="form-control rounded-3" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Status</label>
              <select name="status" class="form-select rounded-3">
                <option value="approved">Approved</option>
                <option value="pending">Pending</option>
                <option value="rejected">Rejected</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">District</label>
              <input type="text" name="district" class="form-control rounded-3">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">City</label>
              <input type="text" name="city" class="form-control rounded-3">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Profile Image URL</label>
              <input type="text" name="profileImage" class="form-control rounded-3">
            </div>
          </div>

          <hr class="my-4">
          <h6 class="fw-bold mb-3"><%= role === 'coach' ? 'Coach Details' : 'Member Details' %></h6>

          <% if (role === 'coach') { %>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-medium">Experience (years)</label>
              <input type="number" name="experience" class="form-control rounded-3">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Rate (Rs./month)</label>
              <input type="number" name="ratePerMonth" class="form-control rounded-3">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Specialties (comma separated)</label>
              <input type="text" name="specialties" class="form-control rounded-3" placeholder="e.g. Weight Loss, Yoga">
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Bio</label>
              <textarea name="bio" class="form-control rounded-3" rows="3"></textarea>
            </div>
          </div>
          <% } else { %>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-medium">Age</label>
              <input type="number" name="age" class="form-control rounded-3">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Gender</label>
              <select name="gender" class="form-select rounded-3">
                <option value="">Select</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Fitness Goals</label>
              <input type="text" name="fitnessGoals" class="form-control rounded-3">
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Health Conditions</label>
              <textarea name="healthConditions" class="form-control rounded-3" rows="2"></textarea>
            </div>
          </div>
          <% } %>

          <div class="mt-4">
            <button type="submit" class="btn btn-success rounded-3 px-5 fw-bold"><i class="bi bi-plus-lg"></i> Add <%= role.charAt(0).toUpperCase() + role.slice(1) %></button>
            <a href="/admin/<%= role %>s" class="btn btn-outline-secondary rounded-3 ms-2">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>