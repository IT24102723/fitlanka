<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center">
      <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3">
        <i class="bi bi-pencil-square fs-2 text-primary"></i>
      </div>
      <div>
        <h4 class="fw-bold mb-0">Edit <%= userData.role.charAt(0).toUpperCase() + userData.role.slice(1) %></h4>
        <p class="text-muted mb-0">Update user details</p>
      </div>
    </div>
    <a href="/admin/<%= userData.role %>s" class="btn btn-outline-secondary rounded-3">Back</a>
  </div>

  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow border-0 rounded-4 p-4">
        <form action="/admin/users/edit/<%= userData._id %>" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-medium">Full Name</label>
              <input type="text" name="name" class="form-control rounded-3" value="<%= userData.name %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Email</label>
              <input type="email" name="email" class="form-control rounded-3" value="<%= userData.email %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Phone</label>
              <input type="text" name="phone" class="form-control rounded-3" value="<%= userData.phone %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">New Password <small class="text-muted">(leave blank to keep)</small></label>
              <input type="password" name="password" class="form-control rounded-3">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Status</label>
              <select name="status" class="form-select rounded-3">
                <option value="approved" <%= userData.status === 'approved' ? 'selected' : '' %>>Approved</option>
                <option value="pending" <%= userData.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="rejected" <%= userData.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">District</label>
              <input type="text" name="district" class="form-control rounded-3" value="<%= userData.district || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">City</label>
              <input type="text" name="city" class="form-control rounded-3" value="<%= userData.city || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium">Profile Image URL</label>
              <input type="text" name="profileImage" class="form-control rounded-3" value="<%= userData.profileImage || '' %>">
            </div>
          </div>

          <hr class="my-4">
          <h6 class="fw-bold mb-3"><%= userData.role === 'coach' ? 'Coach Details' : 'Member Details' %></h6>

          <% if (userData.role === 'coach') { %>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-medium">Experience (years)</label>
              <input type="number" name="experience" class="form-control rounded-3" value="<%= userData.coachDetails?.experience || '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Rate (Rs./month)</label>
              <input type="number" name="ratePerMonth" class="form-control rounded-3" value="<%= userData.coachDetails?.ratePerMonth || '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Specialties (comma separated)</label>
              <input type="text" name="specialties" class="form-control rounded-3" value="<%= (userData.coachDetails?.specialties || []).join(', ') %>">
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Bio</label>
              <textarea name="bio" class="form-control rounded-3" rows="3"><%= userData.coachDetails?.bio || '' %></textarea>
            </div>
          </div>
          <% } else if (userData.role === 'member') { %>
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-medium">Age</label>
              <input type="number" name="age" class="form-control rounded-3" value="<%= userData.memberDetails?.age || '' %>">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Gender</label>
              <select name="gender" class="form-select rounded-3">
                <option value="">Select</option>
                <option value="male" <%= userData.memberDetails?.gender === 'male' ? 'selected' : '' %>>Male</option>
                <option value="female" <%= userData.memberDetails?.gender === 'female' ? 'selected' : '' %>>Female</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-medium">Fitness Goals</label>
              <input type="text" name="fitnessGoals" class="form-control rounded-3" value="<%= userData.memberDetails?.fitnessGoals || '' %>">
            </div>
            <div class="col-12">
              <label class="form-label fw-medium">Health Conditions</label>
              <textarea name="healthConditions" class="form-control rounded-3" rows="2"><%= userData.memberDetails?.healthConditions || '' %></textarea>
            </div>
          </div>
          <% } %>

          <div class="mt-4">
            <button type="submit" class="btn btn-primary rounded-3 px-5 fw-bold"><i class="bi bi-check-lg"></i> Save Changes</button>
            <a href="/admin/<%= userData.role %>s" class="btn btn-outline-secondary rounded-3 ms-2">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>