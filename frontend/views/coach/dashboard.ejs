<%- include('../partials/header') %>

<div class="container py-4">
  <div class="d-flex align-items-center mb-4">
    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3">
      <i class="bi bi-person-badge fs-2 text-warning"></i>
    </div>
    <div>
      <h2 class="fw-bold mb-0">Coach Dashboard</h2>
      <p class="text-muted mb-0">Welcome back, <%= coach.name %>!</p>
    </div>
  </div>
  <div class="row">
    <div class="col-md-4">
      <div class="card shadow border-0 rounded-4 mb-4">
        <div class="card-body text-center p-4">
          <div class="bg-warning bg-opacity-10 d-inline-flex p-3 rounded-circle mx-auto mb-3">
            <i class="bi bi-person-circle fs-1 text-warning"></i>
          </div>
          <h4 class="fw-bold"><%= coach.name %></h4>
          <span class="badge bg-<%= coach.status === 'approved' ? 'success' : 'warning' %> fs-6 px-3">
            <%= coach.status === 'approved' ? 'Approved' : 'Pending Approval' %>
          </span>
        </div>
      </div>
      <div class="card shadow border-0 rounded-4 mb-4">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-3"><i class="bi bi-info-circle text-warning"></i> Profile</h5>
          <p class="mb-1"><strong>Email:</strong> <%= coach.email %></p>
          <p class="mb-1"><strong>Phone:</strong> <%= coach.phone %></p>
          <p class="mb-1"><strong>Experience:</strong> <%= coach.coachDetails?.experience || '-' %> years</p>
          <p class="mb-1"><strong>Rate:</strong> Rs.<%= coach.coachDetails?.ratePerMonth || '-' %>/month</p>
          <p class="mb-1"><strong>Specialties:</strong> <%= (coach.coachDetails?.specialties || []).join(', ') || '-' %></p>
          <p><strong>Bio:</strong> <%= coach.coachDetails?.bio || '-' %></p>
          <hr>
          <h6 class="fw-bold">Certificates:</h6>
          <% if (coach.coachDetails?.certificates && coach.coachDetails.certificates.length > 0) { %>
            <ul class="list-unstyled">
              <% coach.coachDetails.certificates.forEach(cert => { %>
                <li><i class="bi bi-file-earmark-check text-success me-1"></i> <%= cert.name %></li>
              <% }) %>
            </ul>
          <% } else { %>
            <p class="text-muted">No certificates uploaded</p>
          <% } %>
        </div>
      </div>
    </div>
    <div class="col-md-8">
      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="bg-warning bg-opacity-10 p-2 rounded-3 me-2"><i class="bi bi-people-fill text-warning fs-4"></i></div>
            <h5 class="fw-bold mb-0">My Members</h5>
          </div>
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead>
                <tr><th>Name</th><th>Email</th><th>Phone</th><th>Since</th></tr>
              </thead>
              <tbody>
                <% members.forEach(m => { %>
                  <tr>
                    <td class="fw-medium"><%= m.member?.name || 'N/A' %></td>
                    <td><%= m.member?.email || 'N/A' %></td>
                    <td><%= m.member?.phone || 'N/A' %></td>
                    <td><%= new Date(m.createdAt).toLocaleDateString() %></td>
                  </tr>
                <% }) %>
                <% if (members.length === 0) { %>
                  <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-people"></i> No members yet</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
