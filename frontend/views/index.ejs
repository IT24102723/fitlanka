<!-- ===== MAP ===== -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="text-center mb-4">
      <span class="badge bg-warning text-dark px-3 py-2 mb-2">FIND NEAR YOU</span>
      <h2 class="fw-bold display-6">Coaches Across <span class="text-warning">Sri Lanka</span></h2>
      <p class="text-muted">Select a city to find coaches near you</p>
    </div>
    <div class="row justify-content-center mb-4">
      <div class="col-md-6">
        <form method="GET" action="/" id="cityFilterForm">
          <div class="input-group">
            <span class="input-group-text bg-warning text-dark"><i class="bi bi-geo-alt"></i></span>
            <select name="city" class="form-select" onchange="this.form.submit()">
              <option value="">All Cities</option>
              <% if (typeof cities !== 'undefined' && cities.length) { %>
                <% cities.forEach(c => { %>
                  <option value="<%= c %>" <%= filterCity === c ? 'selected' : '' %>><%= c %></option>
                <% }) %>
              <% } %>
            </select>
          </div>
        </form>
      </div>
    </div>
    <div id="map" style="height:400px;border-radius:16px;overflow:hidden;" class="shadow"></div>
  </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function() {
  var map = L.map('map').setView([7.8731, 80.7718], 8);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap',
    maxZoom: 12
  }).addTo(map);

  var coachData = <%- JSON.stringify(coaches.map(function(c) { return { name: c.name, city: c.city || '', id: c._id.toString() }; })) %>;
  var grouped = {};
  coachData.forEach(function(c) {
    if (c.city) { if (!grouped[c.city]) grouped[c.city] = []; grouped[c.city].push(c); }
  });

  var allCities = [
    { name: 'Colombo', coord: [6.9271, 79.8612] },
    { name: 'Gampaha', coord: [7.0915, 79.9990] },
    { name: 'Kalutara', coord: [6.5854, 79.9607] },
    { name: 'Kandy', coord: [7.2906, 80.6337] },
    { name: 'Matale', coord: [7.4658, 80.6236] },
    { name: 'Nuwara Eliya', coord: [6.9707, 80.7829] },
    { name: 'Galle', coord: [6.0535, 80.2210] },
    { name: 'Matara', coord: [5.9549, 80.5549] },
    { name: 'Hambantota', coord: [6.1245, 81.1175] },
    { name: 'Jaffna', coord: [9.6615, 80.0255] },
    { name: 'Kilinochchi', coord: [9.3827, 80.3997] },
    { name: 'Mannar', coord: [8.9823, 79.9110] },
    { name: 'Mullaitivu', coord: [9.2701, 80.8131] },
    { name: 'Vavuniya', coord: [8.7552, 80.4971] },
    { name: 'Puttalam', coord: [8.0355, 79.8283] },
    { name: 'Kurunegala', coord: [7.4867, 80.3646] },
    { name: 'Anuradhapura', coord: [8.3114, 80.4037] },
    { name: 'Polonnaruwa', coord: [7.9397, 81.0020] },
    { name: 'Badulla', coord: [6.9934, 81.0550] },
    { name: 'Moneragala', coord: [6.8766, 81.3516] },
    { name: 'Ratnapura', coord: [6.7056, 80.3845] },
    { name: 'Kegalle', coord: [7.2513, 80.3477] },
    { name: 'Trincomalee', coord: [8.5874, 81.2152] },
    { name: 'Batticaloa', coord: [7.7170, 81.7000] },
    { name: 'Ampara', coord: [7.2970, 81.6823] }
  ];

  var goldIcon = L.divIcon({
    className: 'custom-marker',
    html: '<div style="background:#ffc107;color:#000;width:32px;height:32px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.3);border:2px solid #fff;"><span style="transform:rotate(45deg);font-size:14px;">\uD83C\uDFC5</span></div>',
    iconSize: [32, 32],
    iconAnchor: [16, 32],
    popupAnchor: [0, -32]
  });

  var grayIcon = L.divIcon({
    className: 'custom-marker',
    html: '<div style="background:#9e9e9e;color:#fff;width:24px;height:24px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(0,0,0,0.2);border:2px solid #fff;opacity:0.6;"><span style="transform:rotate(45deg);font-size:11px;">\u2022</span></div>',
    iconSize: [24, 24],
    iconAnchor: [12, 24],
    popupAnchor: [0, -24]
  });

  allCities.forEach(function(city) {
    var coaches = grouped[city.name] || [];
    var hasCoaches = coaches.length > 0;
    var icon = hasCoaches ? goldIcon : grayIcon;
    var names = hasCoaches
      ? coaches.map(function(c) { return '<a href="/coach-profile/' + c.id + '" class="text-decoration-none fw-medium">\uD83D\uDCAA ' + c.name + '</a>'; }).join('<br>')
      : '<span class="text-muted">No coaches yet</span>';
    var popupHtml = '<div style="min-width:150px;">' +
      '<h6 style="margin:0 0 6px;font-weight:700;"><span style="background:#ffc107;padding:2px 10px;border-radius:10px;">' + city.name + '</span></h6>' +
      '<div style="font-size:13px;">' + names + '</div>' +
      '</div>';
    var marker = L.marker(city.coord, { icon: icon }).addTo(map);
    marker.bindPopup(popupHtml, { closeButton: false, offset: [0, -16] });
    marker.on('mouseover', function() { this.openPopup(); });
    marker.on('mouseout', function() { this.closePopup(); });
  });
})();
</script>

