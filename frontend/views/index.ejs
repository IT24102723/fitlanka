<%- include('partials/header') %>

<!-- ===== HERO ===== -->
<section class="hero-section d-flex align-items-center position-relative overflow-hidden">
  <div class="hero-bg"></div>
  <div class="hero-overlay"></div>
  <div class="container position-relative z-3 text-center text-white">
    <p class="text-uppercase fw-bold text-warning tracking-wide mb-3 animate-fade">#1 Fitness Platform in Sri Lanka</p>
    <h1 class="display-3 fw-bold hero-title mb-3">
      Transform Your Body<br>
      <span class="text-warning">Transform Your Life</span>
    </h1>
    <p class="lead mb-4 mx-auto" style="max-width: 600px;">
      Sri Lanka's trusted platform connecting certified coaches with fitness seekers.
      Train smarter with expert guidance tailored just for you.
    </p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <% if (!user) { %>
        <a href="/register" class="btn btn-warning btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg">
          Get Started Free <i class="bi bi-arrow-right ms-2"></i>
        </a>
        <a href="/login" class="btn btn-outline-light btn-lg px-5 py-3 rounded-pill">Login</a>
      <% } else if (user.role === 'member') { %>
        <a href="/member/coaches" class="btn btn-warning btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg">Find Your Coach</a>
      <% } else if (user.role === 'coach') { %>
        <a href="/coach/dashboard" class="btn btn-warning btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg">My Dashboard</a>
      <% } else { %>
        <a href="/admin/dashboard" class="btn btn-warning btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg">Admin Panel</a>
      <% } %>
    </div>
    <div class="row mt-5 pt-4 g-3 justify-content-center">
      <div class="col-4 col-md-2">
        <div class="bg-white bg-opacity-10 rounded-3 p-3 backdrop-blur">
          <div class="fs-2 fw-bold text-warning"><%= stats.coaches %></div>
          <small class="text-white-50">Certified Coaches</small>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="bg-white bg-opacity-10 rounded-3 p-3 backdrop-blur">
          <div class="fs-2 fw-bold text-warning"><%= stats.members %></div>
          <small class="text-white-50">Active Members</small>
        </div>
      </div>
      <div class="col-4 col-md-2">
        <div class="bg-white bg-opacity-10 rounded-3 p-3 backdrop-blur">
          <div class="fs-2 fw-bold text-warning">5</div>
          <small class="text-white-50">Cities Covered</small>
        </div>
      </div>
    </div>
  </div>
</section>

