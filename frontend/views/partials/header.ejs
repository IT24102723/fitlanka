<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FitLanka - Sri Lanka's Premium Gym Network</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">
        <i class="bi bi-bricks"></i> Fit<span class="text-warning">Lanka</span>
      </a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-lg-center">
          <li class="nav-item"><a class="nav-link px-3" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link px-3" href="/coaches">Coaches</a></li>
          <% if (!user) { %>
            <li class="nav-item"><a class="nav-link px-3" href="/login">Login</a></li>
            <li class="nav-item"><a class="nav-link px-3" href="/register">Register</a></li>
          <% } else { %>
            <% if (user.role === 'admin') { %>
              <li class="nav-item"><a class="nav-link px-3" href="/admin/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
            <% } else if (user.role === 'coach') { %>
              <li class="nav-item"><a class="nav-link px-3" href="/coach/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
            <% } else if (user.role === 'member') { %>
              <li class="nav-item"><a class="nav-link px-3" href="/member/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
              <li class="nav-item"><a class="nav-link px-3" href="/member/coaches"><i class="bi bi-search"></i> Find Coaches</a></li>
            <% } %>
            <li class="nav-item ms-lg-2">
              <span class="nav-link text-white-50 small"><i class="bi bi-person-circle"></i> <%= user.name %></span>
            </li>
            <li class="nav-item"><a class="nav-link px-3 text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container mt-3">
    <% if (messages && messages.error && messages.error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show shadow-sm rounded-3 border-0">
        <i class="bi bi-exclamation-triangle me-2"></i><%= messages.error[0] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
    <% if (messages && messages.success && messages.success.length > 0) { %>
      <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3 border-0">
        <i class="bi bi-check-circle me-2"></i><%= messages.success[0] %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
  </div>
